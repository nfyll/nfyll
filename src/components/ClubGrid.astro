---
/**
 * Hard-coded member-club list. The canonical roster will eventually
 * come from LeagueOps via getPrograms() — when that endpoint is live,
 * swap this for a dynamic render. For now this is the 2026-05-24
 * roster Dave confirmed.
 */
import ameliaIsland from '../assets/brand/clubs/amelia-island.png';
import creeks from '../assets/brand/clubs/creeks.png';
import filc from '../assets/brand/clubs/filc.png';
import jaxLax from '../assets/brand/clubs/jax-lax.png';
import ponteVedra from '../assets/brand/clubs/ponte-vedra.png';

const clubs = [
  {
    name: 'Amelia Island Hammerheads',
    logo: ameliaIsland,
    url: '#',
  },
  {
    name: 'Creeks Youth Lacrosse',
    logo: creeks,
    url: 'https://creekslax.com',
  },
  {
    name: 'Fleming Island Lacrosse Club',
    logo: filc,
    url: 'https://filc.us',
  },
  {
    name: 'Jax Lax',
    logo: jaxLax,
    url: '#',
  },
  {
    name: 'Ponte Vedra Riptide Lacrosse',
    logo: ponteVedra,
    url: '#',
  },
];
---
<div class="club-grid">
  {clubs.map((c) => (
    <a class="club-card" href={c.url} target={c.url === '#' ? undefined : '_blank'} rel="noopener">
      <img src={c.logo.src} width={c.logo.width} height={c.logo.height} alt={`${c.name} logo`} loading="lazy" />
      <span>{c.name}</span>
    </a>
  ))}
</div>
<style>
  .club-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
    margin: 1.5rem 0;
  }
  .club-card {
    display: flex; flex-direction: column; align-items: center;
    gap: 0.5rem; padding: 1.25rem 1rem;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 8px;
    color: white; text-align: center; text-decoration: none;
    transition: background 0.15s, border-color 0.15s;
  }
  .club-card:hover {
    background: rgba(255,255,255,0.08);
    border-color: rgba(255,255,255,0.18);
  }
  .club-card img {
    width: 80px; height: 80px; object-fit: contain;
  }
  .club-card span { font-size: 0.9rem; font-weight: 500; }
</style>
