---
export interface Props {
  title?: string;
  description?: string;
  active?: string;
  ogImage?: string;
}

const { title, description, active = '/', ogImage = '/logo.png' } = Astro.props;
const fullTitle = title
  ? `${title} — NFYLL`
  : 'North Florida Youth Lacrosse League';
const desc =
  description ??
  'Spring rec lacrosse league for youth across northeast Florida — Amelia Island, Creeks, Fleming Island, Jax Lax, Ponte Vedra Riptide.';
const ogImageUrl = new URL(ogImage, Astro.url).href;

const navLinks: Array<{ href: string; label: string }> = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/clubs', label: 'Clubs' },
  { href: '/schedule', label: 'Schedule' },
  { href: '/standings', label: 'Standings' },
  { href: '/sponsors', label: 'Sponsors' },
  { href: '/contact', label: 'Contact' },
];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={desc} />
  <meta name="theme-color" content="#0f172a" />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={desc} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={Astro.url.href} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:site_name" content="North Florida Youth Lacrosse League" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={desc} />
  <meta name="twitter:image" content={ogImageUrl} />
  <link rel="icon" type="image/png" href="/logo.png" />
  <link rel="apple-touch-icon" href="/logo.png" />
  <link rel="canonical" href={`https://nfyll.org${Astro.url.pathname}`} />
  <title>{fullTitle}</title>
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SportsOrganization",
    "name": "North Florida Youth Lacrosse League",
    "alternateName": "NFYLL",
    "url": "https://nfyll.org",
    "logo": "https://nfyll.org/logo.png",
    "email": "board@nfyll.org",
    "sport": "Lacrosse",
    "areaServed": "Northeast Florida",
    "nonprofitStatus": "Nonprofit501c3"
  })} />
  <style>
    /*
     * Brand tokens — PLACEHOLDER palette (neutral slate + emerald).
     * Swap with NFYLL's actual brand colors once Dave/Sean confirm them.
     * Search for --brand- across the codebase to find every consumer.
     */
    :root {
      --brand-primary: #0f172a;          /* slate-900 */
      --brand-primary-mid: #1e293b;      /* slate-800 */
      --brand-primary-dark: #020617;     /* slate-950 */
      --brand-accent: #059669;           /* emerald-600 */
      --brand-accent-light: #10b981;     /* emerald-500 */
      --ink: #0f172a;
      --muted: #64748b;
      --muted-light: rgba(255, 255, 255, 0.65);
      --card: #f8fafc;
      --border: #e2e8f0;
    }
    *, *::before, *::after { box-sizing: border-box; }
    html { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; }
    body { margin: 0; color: white; background: var(--brand-primary); line-height: 1.5; }
    a { color: var(--brand-accent-light); }
    a:focus-visible, button:focus-visible {
      outline: 2px solid var(--brand-accent-light);
      outline-offset: 2px;
      border-radius: 2px;
    }
    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after { transition-duration: 0.01ms !important; animation-duration: 0.01ms !important; }
    }
    header.site-header {
      background: rgba(15, 23, 42, 0.96);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      color: white;
      position: sticky; top: 0; z-index: 50;
      border-bottom: 1px solid rgba(255,255,255,0.07);
    }
    .site-header-inner {
      max-width: 1200px; margin: 0 auto;
      padding: 0.75rem 1.5rem;
      display: flex; align-items: center; gap: 2rem;
    }
    .site-header a { color: white; text-decoration: none; font-weight: 500; }
    .site-header a.active { color: var(--brand-accent-light); }
    .site-header a:hover { color: var(--brand-accent-light); }
    .brand {
      display: inline-flex; align-items: center; gap: 0.65rem;
      font-size: 1.1rem; font-weight: 700; letter-spacing: 0.05em;
    }
    .brand-logo { flex-shrink: 0; object-fit: contain; }
    nav.site-nav {
      display: flex; gap: 1.25rem; margin-left: auto; font-size: 0.95rem;
    }
    button.nav-hamburger {
      display: none; margin-left: auto;
      padding: 0.4rem 0.6rem; border: 1px solid rgba(255,255,255,0.18);
      border-radius: 4px; background: rgba(255,255,255,0.04);
      color: white; font: inherit; font-size: 1.15rem; line-height: 1;
      cursor: pointer;
    }
    @media (max-width: 800px) {
      .brand { font-size: 0.85rem; letter-spacing: 0.03em; gap: 0.5rem; }
      .brand-logo { width: 36px; height: 30px; }
      .site-header-inner { padding: 0.6rem 1rem; gap: 0.75rem; position: relative; }
      button.nav-hamburger { display: inline-flex; align-items: center; }
      nav.site-nav { display: none; }
      body.nav-open nav.site-nav {
        display: flex; position: absolute; top: calc(100% + 0.5rem); right: 1rem;
        flex-direction: column; gap: 0; padding: 0.5rem 0;
        background: var(--brand-primary-dark);
        border: 1px solid rgba(255,255,255,0.1); border-radius: 6px;
        min-width: 180px; margin-left: 0;
        box-shadow: 0 8px 24px rgba(0,0,0,0.4); z-index: 60;
      }
      body.nav-open nav.site-nav a {
        padding: 0.6rem 1rem; border-bottom: 1px solid rgba(255,255,255,0.04);
      }
      body.nav-open nav.site-nav a:last-child { border-bottom: none; }
    }
    main { min-height: calc(100vh - 200px); padding: 0 0 3rem; }
    .container { max-width: 1100px; margin: 0 auto; padding: 0 1.5rem; }
    .hero {
      padding: 4rem 1.5rem 3rem;
      text-align: center;
      background: linear-gradient(180deg, var(--brand-primary-mid), var(--brand-primary));
    }
    .hero h1 { font-size: 2.5rem; margin: 0 0 0.5rem; }
    .hero p { color: var(--muted-light); max-width: 600px; margin: 0 auto; }
    h2 { font-size: 1.75rem; margin-top: 2.5rem; }
    .empty-state {
      padding: 2.5rem 1.5rem;
      text-align: center;
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 8px;
      color: var(--muted-light);
    }
    footer.site-footer {
      background: var(--brand-primary-dark);
      border-top: 1px solid rgba(255,255,255,0.07);
      color: rgba(255,255,255,0.6);
      font-size: 0.8rem;
      padding: 1.5rem;
    }
    .site-footer-inner {
      max-width: 1200px; margin: 0 auto;
      display: flex; justify-content: space-between; align-items: center;
      gap: 1rem; flex-wrap: wrap;
    }
    .site-footer a { color: var(--brand-accent-light); }
  </style>
  <slot name="head" />
</head>
<body>
  <header class="site-header">
    <div class="site-header-inner">
      <a href="/" class="brand">
        <img src="/logo.png" alt="" width="50" height="42" class="brand-logo" loading="eager" />
        <span>NFYLL</span>
      </a>
      <button class="nav-hamburger" type="button" aria-label="Menu" aria-expanded="false" aria-controls="site-nav">☰</button>
      <nav id="site-nav" class="site-nav">
        {navLinks.map((link) => (
          <a href={link.href} class={active === link.href ? 'active' : ''}>{link.label}</a>
        ))}
      </nav>
    </div>
  </header>
  <main>
    <slot />
  </main>
  <footer class="site-footer">
    <div class="site-footer-inner">
      <span>© {new Date().getFullYear()} North Florida Youth Lacrosse League · 501(c)(3) nonprofit</span>
      <span>
        Questions? <a href="mailto:board@nfyll.org">board@nfyll.org</a>
      </span>
    </div>
  </footer>
  <script is:inline>
    (function () {
      const btn = document.querySelector('button.nav-hamburger');
      if (!btn) return;
      const nav = document.getElementById('site-nav');
      function setOpen(open) {
        document.body.classList.toggle('nav-open', open);
        btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      }
      btn.addEventListener('click', function (e) {
        e.stopPropagation();
        setOpen(!document.body.classList.contains('nav-open'));
      });
      document.addEventListener('click', function (e) {
        if (!document.body.classList.contains('nav-open')) return;
        if (!nav.contains(e.target) && e.target !== btn) setOpen(false);
      });
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && document.body.classList.contains('nav-open')) setOpen(false);
      });
    })();
  </script>
</body>
</html>
