---
export interface Props {
  title?: string;
  description?: string;
  active?: string;
  ogImage?: string;
}

const { title, description, active = '/', ogImage = '/hero-map.png' } = Astro.props;
const fullTitle = title
  ? `${title} — NFYLL`
  : 'North Florida Youth Lacrosse League';
const desc =
  description ??
  'Boys youth lacrosse, grades PK–8, across northeast Florida. Eight member clubs. One Saturday-morning venue. One spring season a year.';
const ogImageUrl = new URL(ogImage, Astro.url).href;

const navLinks: Array<{ href: string; label: string }> = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/clubs', label: 'Clubs' },
  { href: '/schedule', label: 'Schedule' },
  { href: '/sponsors', label: 'Sponsors' },
  { href: '/contact', label: 'Contact' },
];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={desc} />
  <meta name="theme-color" content="#1B4D7E" />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={desc} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={Astro.url.href} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:site_name" content="North Florida Youth Lacrosse League" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={desc} />
  <meta name="twitter:image" content={ogImageUrl} />
  <link rel="icon" type="image/png" href="/logo.png" />
  <link rel="apple-touch-icon" href="/logo.png" />
  <link rel="canonical" href={`https://nfyll.org${Astro.url.pathname}`} />
  <!-- Self-host-friendly Google Fonts: Fraunces (display) + Inter (body) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&display=swap" />
  <title>{fullTitle}</title>
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SportsOrganization",
    "name": "North Florida Youth Lacrosse League",
    "alternateName": "NFYLL",
    "url": "https://nfyll.org",
    "logo": "https://nfyll.org/logo.png",
    "email": "board@nfyll.org",
    "sport": "Lacrosse",
    "areaServed": "Northeast Florida",
    "nonprofitStatus": "Nonprofit501c3",
    "location": {
      "@type": "Place",
      "name": "Julington Creek Plantation Park",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "3060 Racetrack Rd",
        "addressLocality": "St. Johns",
        "addressRegion": "FL",
        "postalCode": "32259",
        "addressCountry": "US"
      }
    }
  })} />
  <style>
    /*
     * NFYLL brand tokens — palette confirmed 2026-05-25.
     * "Civic Cartography" identity: light-mode, River-Blue + Sunshine-Orange + Sand-Gold.
     * Deliberately distinct from FILC's dark navy + emerald.
     */
    :root {
      --river-blue: #1B4D7E;          /* primary */
      --deep-river: #103657;          /* deep primary — footer, sticky surfaces */
      --sky-wash: #E8F0F7;            /* page background */
      --sky-wash-deep: #DFE9F2;       /* gradient pair for hero */
      --sunshine: #F2823C;            /* accent — CTAs, dots, active nav */
      --sunshine-soft: rgba(242, 130, 60, 0.12);
      --sand-gold: #F4C24B;           /* secondary accent — off-season banner, sponsors */
      --sand-gold-soft: rgba(244, 194, 75, 0.18);
      --ink: #1A2733;                 /* body text */
      --muted: #5A6B7B;               /* captions, meta */
      --hairline: #D6DEE6;            /* borders, dividers */
      --white: #FFFFFF;

      --shadow-card: 0 1px 2px rgba(16, 54, 87, 0.04), 0 4px 12px rgba(16, 54, 87, 0.06);
      --shadow-card-hover: 0 4px 14px rgba(16, 54, 87, 0.12);
    }
    *, *::before, *::after { box-sizing: border-box; }
    html {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      color: var(--ink);
      background: var(--sky-wash);
    }
    body {
      margin: 0;
      color: var(--ink);
      background: var(--sky-wash);
      line-height: 1.55;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }
    h1, h2, h3 {
      font-family: 'Fraunces', Georgia, 'Times New Roman', serif;
      color: var(--deep-river);
      font-weight: 600;
      letter-spacing: -0.01em;
    }
    h1 {
      font-variation-settings: 'opsz' 144;
      font-weight: 700;
      line-height: 1.05;
      margin: 0 0 0.5rem;
    }
    h2 {
      font-variation-settings: 'opsz' 36;
      font-size: clamp(1.5rem, 2.4vw, 2rem);
      margin: 2.5rem 0 1rem;
      line-height: 1.15;
    }
    h3 {
      font-variation-settings: 'opsz' 24;
      font-size: 1.25rem;
      margin: 1.5rem 0 0.75rem;
      line-height: 1.2;
    }
    p { margin: 0 0 1rem; }
    a {
      color: var(--river-blue);
      text-decoration: underline;
      text-decoration-thickness: 1px;
      text-underline-offset: 2px;
      transition: color 0.15s;
    }
    a:hover { color: var(--sunshine); }
    a:focus-visible, button:focus-visible {
      outline: 2px solid var(--sunshine);
      outline-offset: 2px;
      border-radius: 2px;
    }
    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after { transition-duration: 0.01ms !important; animation-duration: 0.01ms !important; }
    }

    /* Header */
    header.site-header {
      background: var(--white);
      color: var(--ink);
      position: sticky; top: 0; z-index: 50;
      border-bottom: 1px solid var(--hairline);
    }
    .site-header-inner {
      max-width: 1200px; margin: 0 auto;
      padding: 0.85rem 1.5rem;
      display: flex; align-items: center; gap: 2rem;
    }
    .site-header a {
      color: var(--ink); text-decoration: none; font-weight: 500;
      font-size: 0.95rem;
    }
    .site-header a.active { color: var(--sunshine); font-weight: 600; }
    .site-header a:hover { color: var(--sunshine); }
    .brand {
      display: inline-flex; align-items: center; gap: 0.65rem;
      font-family: 'Fraunces', serif;
      font-variation-settings: 'opsz' 24;
      font-size: 1.15rem; font-weight: 700; letter-spacing: 0.02em;
      color: var(--deep-river) !important;
    }
    .brand:hover { color: var(--river-blue) !important; }
    .brand-logo { flex-shrink: 0; object-fit: contain; }
    nav.site-nav {
      display: flex; gap: 1.5rem; margin-left: auto;
    }
    button.nav-hamburger {
      display: none; margin-left: auto;
      padding: 0.4rem 0.6rem; border: 1px solid var(--hairline);
      border-radius: 4px; background: var(--white);
      color: var(--ink); font: inherit; font-size: 1.15rem; line-height: 1;
      cursor: pointer;
    }
    @media (max-width: 800px) {
      .brand { font-size: 0.95rem; letter-spacing: 0.01em; gap: 0.5rem; }
      .brand-logo { width: 36px; height: 30px; }
      .site-header-inner { padding: 0.6rem 1rem; gap: 0.75rem; position: relative; }
      button.nav-hamburger { display: inline-flex; align-items: center; }
      nav.site-nav { display: none; }
      body.nav-open nav.site-nav {
        display: flex; position: absolute; top: calc(100% + 0.5rem); right: 1rem;
        flex-direction: column; gap: 0; padding: 0.5rem 0;
        background: var(--white);
        border: 1px solid var(--hairline); border-radius: 6px;
        min-width: 180px; margin-left: 0;
        box-shadow: var(--shadow-card-hover); z-index: 60;
      }
      body.nav-open nav.site-nav a {
        padding: 0.6rem 1rem; border-bottom: 1px solid var(--hairline);
      }
      body.nav-open nav.site-nav a:last-child { border-bottom: none; }
    }

    main { min-height: calc(100vh - 220px); padding: 0 0 4rem; }
    .container { max-width: 1100px; margin: 0 auto; padding: 0 1.5rem; }

    /* Default fallback hero (overridden on Home) */
    .hero {
      padding: 4rem 1.5rem 3rem;
      text-align: left;
      background: linear-gradient(180deg, var(--sky-wash), var(--sky-wash-deep));
      border-bottom: 1px solid var(--hairline);
    }
    .hero h1 { font-size: clamp(2rem, 4.5vw, 3rem); margin: 0 0 0.75rem; }
    .hero p { color: var(--muted); max-width: 640px; margin: 0; font-size: 1.1rem; }
    .hero .container { padding: 0 1.5rem; }

    /* Generic empty/state callout (used for "no schedule yet" etc.) */
    .empty-state {
      padding: 2rem 1.5rem;
      background: var(--white);
      border: 1px solid var(--hairline);
      border-radius: 8px;
      color: var(--muted);
      text-align: center;
    }
    .empty-state strong { color: var(--ink); }

    /* Pill / eyebrow text used widely */
    .eyebrow {
      font-family: 'Inter', sans-serif;
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--sunshine);
    }

    /* Footer */
    footer.site-footer {
      background: var(--deep-river);
      color: rgba(255, 255, 255, 0.7);
      font-size: 0.85rem;
      padding: 2rem 1.5rem 1.5rem;
    }
    .site-footer-inner {
      max-width: 1200px; margin: 0 auto;
      display: grid;
      grid-template-columns: 1.6fr 1fr 1fr;
      gap: 2rem;
      align-items: start;
    }
    .site-footer h4 {
      color: white;
      font-family: 'Fraunces', serif;
      font-variation-settings: 'opsz' 24;
      font-size: 0.95rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      margin: 0 0 0.65rem;
      text-transform: uppercase;
    }
    .site-footer ul { list-style: none; margin: 0; padding: 0; }
    .site-footer ul li { margin-bottom: 0.35rem; }
    .site-footer a { color: rgba(255,255,255,0.85); text-decoration: none; }
    .site-footer a:hover { color: var(--sand-gold); }
    .site-footer-legal {
      max-width: 1200px;
      margin: 1.5rem auto 0;
      padding-top: 1rem;
      border-top: 1px solid rgba(255,255,255,0.12);
      color: rgba(255,255,255,0.55);
      font-size: 0.78rem;
    }
    @media (max-width: 800px) {
      .site-footer-inner { grid-template-columns: 1fr; gap: 1.5rem; }
    }
  </style>
  <slot name="head" />
</head>
<body>
  <header class="site-header">
    <div class="site-header-inner">
      <a href="/" class="brand">
        <img src="/logo.png" alt="" width="40" height="34" class="brand-logo" loading="eager" />
        <span>NFYLL</span>
      </a>
      <button class="nav-hamburger" type="button" aria-label="Menu" aria-expanded="false" aria-controls="site-nav">☰</button>
      <nav id="site-nav" class="site-nav">
        {navLinks.map((link) => (
          <a href={link.href} class={active === link.href ? 'active' : ''}>{link.label}</a>
        ))}
      </nav>
    </div>
  </header>
  <main>
    <slot />
  </main>
  <footer class="site-footer">
    <div class="site-footer-inner">
      <div>
        <h4>NFYLL</h4>
        <p style="margin: 0 0 0.5rem; color: rgba(255,255,255,0.75);">North Florida Youth Lacrosse League</p>
        <p style="margin: 0; font-size: 0.8rem; color: rgba(255,255,255,0.55);">
          A 501(c)(3) nonprofit. Boys youth lacrosse, grades PK–8, across northeast Florida.
        </p>
      </div>
      <div>
        <h4>League</h4>
        <ul>
          <li><a href="/about">About</a></li>
          <li><a href="/clubs">Member Clubs</a></li>
          <li><a href="/schedule">Schedule</a></li>
          <li><a href="/sponsors">Sponsors</a></li>
        </ul>
      </div>
      <div>
        <h4>Visit + Contact</h4>
        <ul>
          <li>Julington Creek Plantation Park</li>
          <li style="font-size: 0.8rem; color: rgba(255,255,255,0.55);">3060 Racetrack Rd · St. Johns, FL 32259</li>
          <li style="margin-top: 0.5rem;"><a href="mailto:board@nfyll.org">board@nfyll.org</a></li>
        </ul>
      </div>
    </div>
    <div class="site-footer-legal">
      © {new Date().getFullYear()} North Florida Youth Lacrosse League · 501(c)(3) nonprofit · EIN 83-2612765
    </div>
  </footer>
  <script is:inline>
    (function () {
      const btn = document.querySelector('button.nav-hamburger');
      if (!btn) return;
      const nav = document.getElementById('site-nav');
      function setOpen(open) {
        document.body.classList.toggle('nav-open', open);
        btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      }
      btn.addEventListener('click', function (e) {
        e.stopPropagation();
        setOpen(!document.body.classList.contains('nav-open'));
      });
      document.addEventListener('click', function (e) {
        if (!document.body.classList.contains('nav-open')) return;
        if (!nav.contains(e.target) && e.target !== btn) setOpen(false);
      });
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && document.body.classList.contains('nav-open')) setOpen(false);
      });
    })();
  </script>
</body>
</html>
