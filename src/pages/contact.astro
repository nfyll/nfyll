---
import Base from '../layouts/Base.astro';
---
<Base title="Contact" active="/contact">
  <div class="container">
    <h2>Contact</h2>
    <p>
      For all league inquiries — registration, board questions, sponsorships,
      schedule changes — email
      <a href="mailto:board@nfyll.org">board@nfyll.org</a>.
    </p>
    <p>
      For information about a specific club, contact that club directly from the
      <a href="/clubs">Member Clubs</a> page.
    </p>
  </div>
</Base>
