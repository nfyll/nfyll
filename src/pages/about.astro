---
import Base from '../layouts/Base.astro';
---
<Base title="About" active="/about">
  <div class="container">
    <h2>About NFYLL</h2>
    <p>
      North Florida Youth Lacrosse League is a 501(c)(3) nonprofit organizing
      spring rec lacrosse for youth players across northeast Florida.
    </p>

    <h2>Board</h2>
    <ul>
      <li><strong>David Vernon</strong> — Director</li>
      <li><strong>Sean Packer</strong> — Director</li>
    </ul>

    <h2>Mission</h2>
    <p>
      Grow the sport of lacrosse in northeast Florida through accessible
      youth play across our partner clubs.
    </p>

    <h2>Contact</h2>
    <p>
      <a href="mailto:board@nfyll.org">board@nfyll.org</a>
    </p>
  </div>
</Base>
